# ─────────────────────────────────────────────────────────────────────────────
# Rexell AI Bot Detection — Environment Variables (Local / FastAPI Stack)
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Databases & Infrastructure ──────────────────────────────────────────────
# PostgreSQL (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://rexell_user:rexell_password@localhost:5432/bot_detection

# Redis (Caching + Fallback flags)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (Alerts + Async jobs)
RABBITMQ_URL=amqp://rexell_user:rexell_password@localhost:5672/

# ── Service Connectivity ──────────────────────────────────────────────────
# The URL where the ML Inference service is reachable
ML_INFERENCE_URL=http://localhost:8080

# ── Security & Authentication ──────────────────────────────────────────────
# Comma-separated list of valid API keys for Detection & Challenge services
DETECTION_API_KEYS=dev-key-1,dev-key-2
CHALLENGE_API_KEYS=dev-key-1,dev-key-2

# HMAC-SHA256 key for signing verification tokens (Use a 32-byte hex string)
TOKEN_SIGNING_KEY=replace-with-32-byte-hex-or-random-string

# Salt used for consistent wallet hashing in analytics
WALLET_SALT=replace-with-random-salt-string

# ── Risk Configuration ────────────────────────────────────────────────────
# Score threshold above which requests are blocked (0-100)
RISK_THRESHOLD_BLOCK=80

# Score threshold above which users are challenged (0-100)
RISK_THRESHOLD_CHALLENGE=50

# Whether to allow traffic to pass if core dependencies (DB/Redis) are down
FALLBACK_CONTROLLER_ENABLED=true

# ── Storage (MinIO / S3) ──────────────────────────────────────────────────
# MinIO endpoint for model artifacts and data archival
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=rexell_admin
MINIO_SECRET_KEY=rexell_password
MINIO_SECURE=false

# Bucket names for models and archived data
MINIO_MODEL_BUCKET=bot-detection-models
MINIO_ARCHIVE_BUCKET=bot-detection-archive

# ── Development Toggles ───────────────────────────────────────────────────
# If true, enables an insecure default key 'dev-local-key' for testing
DETECTION_DEV_MODE=false
CHALLENGE_DEV_MODE=false
