{
  "title": "Rexell Bot Detection — Decisions & Model",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Detection rate (block+challenge / total)",
      "targets": [
        {
          "expr": "sum(rate(bot_detection_requests_total{decision=~\"block|challenge\"}[5m])) / clamp_min(sum(rate(bot_detection_requests_total[5m])), 1)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Risk-score distribution",
      "targets": [
        {
          "expr": "sum by (le) (rate(bot_detection_risk_score_histogram_bucket[5m]))",
          "format": "heatmap"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Challenge completion rate",
      "targets": [{"expr": "avg(challenge_completion_rate)"}]
    },
    {
      "type": "stat",
      "title": "Model accuracy (current version)",
      "targets": [{"expr": "max(bot_detection_model_accuracy)"}]
    }
  ]
}
